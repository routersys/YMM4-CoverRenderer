<UserControl x:Class="CoverRenderer.CoverSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CoverRenderer"
             Name="root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate x:Key="SelectedTemplate">
            <TextBlock VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="2,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="{Binding FileName}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNone}" Value="True">
                                <Setter Property="Text" Value="{x:Static local:Texts.NotSelected}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="DropdownTemplate">
            <Grid Height="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="2,0,4,0">
                    <TextBlock Text="{x:Static local:Texts.NotSelected}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding IsNone, Converter={StaticResource BoolToVis}}"/>
                    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNone}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Image Source="{Binding Thumbnail}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Column="1"
                           Text="{Binding FileName}"
                           VerticalAlignment="Center"
                           Margin="4,0"
                           TextWrapping="Wrap"
                           TextTrimming="None">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNone}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <local:FileEntryTemplateSelector x:Key="TemplateSelector"
                                         SelectedTemplate="{StaticResource SelectedTemplate}"
                                         DropdownTemplate="{StaticResource DropdownTemplate}"/>
    </UserControl.Resources>

    <Grid Height="26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="26"/>
        </Grid.ColumnDefinitions>

        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding Files}"
                  SelectedItem="{Binding SelectedFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  ItemTemplateSelector="{StaticResource TemplateSelector}"
                  VerticalContentAlignment="Center"
                  MaxDropDownHeight="320">
            <ComboBox.Style>
                <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                    <Style.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ComboBox.Style>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <Button Grid.Column="1"
                Command="{Binding DataContext.BrowseCommand, ElementName=root}"
                Padding="4,0">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"/>
            </Button.Style>
            <Path Data="M6.1,10L4,18V8H21A2,2 0 0,0 19,6H12L10,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H19C19.9,20 20.7,19.4 20.9,18.5L23.2,10H6.1M19,18H6L7.6,12H20.6L19,18Z"
                  Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                  Width="14" Height="14"
                  Stretch="Uniform"/>
        </Button>
    </Grid>
</UserControl>
